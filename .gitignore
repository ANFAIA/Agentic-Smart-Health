# =============================================================================
# Agentic Smart Health — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
MANIFEST

# -----------------------------------------------------------------------------
# Entornos virtuales
# -----------------------------------------------------------------------------
.venv/
venv/
env/
.env/

# -----------------------------------------------------------------------------
# uv
# -----------------------------------------------------------------------------
.uv/

# -----------------------------------------------------------------------------
# Variables de entorno y secretos
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.secret
*.key
secrets/

# -----------------------------------------------------------------------------
# Datos clínicos y archivos sensibles
# -----------------------------------------------------------------------------
# NO se versionan por tres motivos: (1) pesan (mallas/volúmenes de varios GB),
# (2) reproducibilidad — se regeneran desde su origen, no se guardan en git:
#     - data/raw/       = dataset de origen  -> scripts/fetch_teeth3ds.sh
#     - data/processed/ = artefactos derivados (.ply, vistas, transforms.json)
#                         -> los generan los notebooks/ al ejecutarse
#     - data/external/  = terceros
# (3) licencia/soberanía del dato: no redistribuir datos clínicos vía el repo.
data/raw/
data/processed/
data/external/
*.dcm
*.nii
*.nii.gz
*.nrrd
*.mha
*.mhd
*.mnc
*.img
*.hdr

# -----------------------------------------------------------------------------
# Jupyter Notebooks
# -----------------------------------------------------------------------------
notebooks/.ipynb_checkpoints/
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Testing y cobertura
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# -----------------------------------------------------------------------------
# Linting y type checking
# -----------------------------------------------------------------------------
.ruff_cache/
.mypy_cache/

# -----------------------------------------------------------------------------
# IDEs y editores
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# macOS / Windows
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Logs y temporales
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
tmp/
temp/

# -----------------------------------------------------------------------------
# Qdrant vector database (research-agent)
# -----------------------------------------------------------------------------
data/research-agent/.qdrant_data/

# -----------------------------------------------------------------------------
# Modelos y artefactos grandes (3DGS, ML)
# -----------------------------------------------------------------------------
*.ply
*.splat
*.ckpt
*.pt
*.pth
*.safetensors
.claude/settings.local.json
